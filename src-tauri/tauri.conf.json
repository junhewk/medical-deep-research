{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemastore/master/schemas/json/tauri-config.json",
  "productName": "Medical Deep Research",
  "version": "2.0.0",
  "identifier": "com.medical-deep-research.app",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "./resources/splash"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Medical Deep Research",
        "width": 1280,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:*; script-src 'self' 'unsafe-inline' http://127.0.0.1:*; style-src 'self' 'unsafe-inline' http://127.0.0.1:*; img-src 'self' data: http://127.0.0.1:*; connect-src 'self' http://127.0.0.1:*; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/**/*"
    ],
    "externalBin": [
      "binaries/bun"
    ],
    "category": "Medical",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "entitlements": null,
      "signingIdentity": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
